//tsconfig.json     

{
  "compilerOptions": {
    "target": "ES2022",

    "lib": ["dom", "dom.iterable", "esnext"],

    "allowJs": true,

    "skipLibCheck": true,

    "strict": true,

    "noEmit": true,

    "esModuleInterop": true,

    "module": "esnext",

    "moduleResolution": "bundler",

    "allowImportingTsExtensions": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "jsx": "react-jsx",

    "incremental": true,

    "plugins": [
      {
        "name": "next"
      }
    ],

    "types": ["node"],

    "baseUrl": ".",

    "paths": {
      "@/*": ["./*"]
    },

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "next-env.d.ts",
    "global.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist-poller",
    "**/*.poller.ts",
    "pdf-server"
  ]
}
